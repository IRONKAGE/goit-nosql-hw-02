# ==============================================================================
# 🌍 ENVIRONMENT VARIABLES (ArXiv AI Researcher Platform) by IRONKAGE
# ==============================================================================
# УВАГА: Файл .env додано до .gitignore.
# Заповніть цей шаблон реальними даними та збережіть як .env у корені проекту

# --- 1. Режим роботи (Яку інфраструктуру використовують Python-скрипти) ---
# Доступні значення: local (Docker Емулятор) або cloud (Офіційний Pinecone SaaS)
ACTIVE_ENV=local  # 'local' для локального контейнера або 'cloud' для віддаленої хмари

# --- 2. Налаштування Хмарного Векторного Простору (Cloud Pinecone) ---
# Необхідно отримати безкоштовний API-ключ у консолі app.pinecone.io (Starter Tier)
# Використовується автоматично, якщо ACTIVE_ENV=cloud
PINECONE_API_KEY=your_actual_cloud_api_key_here

# --- 3. Налаштування Локального Емулятора (Local Pinecone Container) ---
# Використовується, якщо ACTIVE_ENV=local. Скрипти будуть направляти векторні
# запити на офіційний образ ghcr.io/pinecone-io/pinecone-local:latest на порт 5080
PINECONE_LOCAL_HOST=http://127.0.0.1:5080

# --- 4. Kaggle API Credentials (ОПЦІОНАЛЬНО) ---
# Якщо ці поля порожні або відсутні, завантаження відбудеться напряму (без API)
KAGGLE_USERNAME=
KAGGLE_KEY=
